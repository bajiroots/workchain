{
  "name": "workchain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "compile": "hardhat compile && node scripts/export-abis.mjs",
    "export:abis": "node scripts/export-abis.mjs",
    "test": "pnpm test:contracts",
    "test:contracts": "hardhat test",
    "node:local": "hardhat node",
    "deploy:local": "hardhat ignition deploy ignition/modules/WorkChain.ts",
    "deploy:localhost": "hardhat --network localhost ignition deploy ignition/modules/WorkChain.ts --reset && node scripts/sync-local-env.mjs",
    "seed:localhost": "hardhat --network localhost run scripts/seed-local.ts",
    "deploy:sepolia": "hardhat --network sepolia ignition deploy ignition/modules/WorkChain.ts && node scripts/sync-sepolia-env.mjs",
    "use:sepolia": "node scripts/sync-sepolia-env.mjs"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@rainbow-me/rainbowkit": "2.2.11",
    "@tanstack/react-query": "5.90.16",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "2.52.2",
    "wagmi": "2.19.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "3.1.7",
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "dotenv": "17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "hardhat": "3.9.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.2"
}
